            "size": 1439,
            "mimeType": "application/json",
            "text": "{\"result\":{\"asin\":\"B0GGR9G48Q\",\"imageUrl\":\"https://m.media-amazon.com/images/I/31eYk5Z9-fL._SS180_.jpg\",\"productTitle\":\"GGTE 271001727 Watercraft Reverse Handle for Sea-Doo 2011 Gts Pro 130 Compatible with 2009–2012 Wake Series Models\",\"featureBullets\":[\"Compatibility: 271001727 compatible with Sea-Doo Sport Cruiser and WAKE series models introduced between 2009 and 2012 and first-generation standard iBR handlebar.\",\"Premium Materials: Reverse handle constructed from high-strength materials, it offers excellent impact resistance, a smooth feel, and remains resistant to aging and deformation over extended use.\",\"Practicality: 2011 gts pro 130 reverse handle single-hand operation delivers intelligent deceleration, precise reversing, and agile docking for watercraft, greatly simplifying low-speed navigation and berthing procedures.\",\"Easy Installation: Reverse handle simple installation, standard craftsmanship, perfect fit, reliable performance.\",\"After-Sales Service: We stand behind our product quality! Should you encounter any issues or have questions, please contact us immediately. Your satisfaction is our top priority, and we will provide full support throughout.\"],\"byLineContributors\":[\"GGTE\"],\"catalogSize\":null,\"taxCurrency\":\"USD\",\"taxValue\":19.99,\"promotionId\":\"A2N9SYHWOGCXSD\",\"purchasePolicyCode\":\"AmazonVine\",\"asinTangoEligible\":true,\"productSiteLaunchDate\":1768380068270,\"limitedQuantity\":false},\"error\":null}"
