            "text": "{\"result\":{\"asin\":\"B0GQ98Z1LK\",\"imageUrl\":\"https://m.media-amazon.com/images/I/51cCQd58T1L._SS180_.jpg\",\"productTitle\":\"7x5ft Glitter Pink Prom 2026 Backdrop Pink Sequin Class of 2026 Congratulations Photography Background Congrats Grad Classroom Decoration Banner\",\"featureBullets\":[\"Packaging: You will receive 1pcs 7x5 ft pink prom 2026 graduation backdrop, enough to meet your decoration needs and make it an unforgettable party\",\"Material: Made of polyester material, the class of 2026 congratulations party supplies are reusable and not easily wrinkled. They are lightweight, and simple to install, ensuring a hassle-free setup for your congrats grad banner\",\"Widely applicable: Suitable for decoration in various occasions, such as girl graduation themed parties, prom send off 2026 party, live streams, outdoor class of 2026 congrats grad photography, etc, helping you create a pleasant party atmosphere\",\"Note: Because of the rules of post office, Item will send by folded. If there are any crease above, please do not worry, crease will not affect your us\",\"After sales service: If you have any questions, please feel free to contact us and we will do our best to solve the problem for you\"],\"byLineContributors\":[\"CSFENPPAO\"],\"catalogSize\":null,\"taxCurrency\":\"USD\",\"taxValue\":9.99,\"promotionId\":\"A1V3GARRC884II\",\"purchasePolicyCode\":\"AmazonVine\",\"asinTangoEligible\":true,\"productSiteLaunchDate\":1772075074890,\"limitedQuantity\":false},\"error\":null}"
