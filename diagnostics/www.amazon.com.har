          "cookies": [],
          "content": {
            "size": 1727,
            "mimeType": "application/json",
            "text": "{\"result\":{\"asin\":\"B0GGGD8VTC\",\"imageUrl\":\"https://m.media-amazon.com/images/I/41w7+7wyi8L._SS180_.jpg\",\"productTitle\":\"Hydraulic Brake Caliper Bracket Kit for Mini Bike, Compatible with Monster Mega Moto MMB80 MMB105 80cc 105cc, For Coleman RB100 RT100, For FRP GMB100 98cc 99cc Minibike Parts\",\"featureBullets\":[\"【Wide Compatibility】: Specifically engineered for small 51mm hydraulic brake calipers, this bracket directly fits popular mini bike models including the MM-B80, MM-B105, GMB100, Coleman B100/RB100, and similar 80cc-105cc bikes.\",\"【Superior Hydraulic Braking Performance】: Easily upgrade from standard cable brakes to a responsive hydraulic system. Achieve precise control and significantly improved stopping power for a safer ride.\",\"【Direct Bolt-On Installation】: Features pre-aligned mounting holes for a straightforward, hassle-free setup. No drilling or frame modifications are required—simply install using the included hardware for a quick conversion.\",\"【Robust & Durable Build】: Crafted from high-strength steel with precision laser cutting, this bracket ensures exceptional sturdiness and secure caliper alignment. A corrosion-resistant coating provides added protection for long-lasting durability.\",\"【Lightweight & Optimized Design】: Engineered with a hollowed-out, skeletonized structure that reduces overall weight without compromising strength. This design contributes to a more agile and responsive riding experience.\"],\"byLineContributors\":[\"Rogierra\"],\"catalogSize\":null,\"taxCurrency\":\"USD\",\"taxValue\":19.99,\"promotionId\":\"A3W3DZD9CJ0XJT\",\"purchasePolicyCode\":\"AmazonVine\",\"asinTangoEligible\":true,\"productSiteLaunchDate\":1768277687044,\"limitedQuantity\":false},\"error\":null}"
          },
          "redirectURL": "",
          "headersSize": -1,
          "bodySize": -1,
